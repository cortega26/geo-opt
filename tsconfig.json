{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "allowJs": false,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  },
  "include": ["index.d.ts", "tests/consumer.test.ts"]
}
