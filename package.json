{
  "name": "geo-opt",
  "version": "2.0.0",
  "description": "Source-available Generative Engine Optimization audit and structured-data CLI",
  "main": "src/index.js",
  "types": "index.d.ts",
  "bin": {
    "geo-opt": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "COMMERCIAL-LICENSE.md",
    "LICENSE-HISTORY.md",
    "LEGACY-MIT-LICENSE",
    "docs/"
  ],
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 node --test tests/*.test.js",
    "test:python": "python3 .agents/skills/geo-optimization/scripts/test_optimizer.py",
    "lint": "eslint src/ bin/ scripts/",
    "format": "prettier --write src/ bin/ scripts/ tests/",
    "format:check": "prettier --check src/ bin/ scripts/ tests/",
    "changelog:check": "node scripts/check-changelog.js",
    "check": "npm run lint && npm run format:check && npm test && npm run test:python && npm run changelog:check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "geo",
    "seo",
    "rag",
    "llm",
    "search",
    "google-gemini",
    "chatgpt",
    "perplexity",
    "citations",
    "schema"
  ],
  "author": "Carlos Ortega González",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortega26/GEO-skill.git"
  },
  "bugs": {
    "url": "https://github.com/cortega26/GEO-skill/issues"
  },
  "homepage": "https://github.com/cortega26/GEO-skill#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "marked": "^18.0.5",
    "zod": "^4.4.3"
  }
}
