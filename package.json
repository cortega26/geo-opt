{
  "name": "geo-opt",
  "version": "2.0.0",
  "description": "Source-available AI discoverability audit, JSON-LD, robots.txt, and llms.txt CLI",
  "main": "dist/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "geo-opt": "dist/bin/cli.js"
  },
  "files": [
    "dist/",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "COMMERCIAL-LICENSE.md",
    "LICENSE-HISTORY.md",
    "LEGACY-MIT-LICENSE",
    "docs/"
  ],
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 node --test tests/*.test.js",
    "test:python": "python3 .agents/skills/geo-optimization/scripts/test_optimizer.py",
    "test:conformance": "node --test tests/conformance.test.js",
    "lint": "eslint src/ bin/ scripts/ && python3 -m py_compile .agents/skills/geo-optimization/scripts/geo_optimizer.py .agents/skills/geo-optimization/scripts/test_optimizer.py",
    "format": "prettier --write src/ bin/ scripts/ tests/",
    "format:check": "prettier --check src/ bin/ scripts/ tests/",
    "changelog:check": "node scripts/check-changelog.js",
    "build": "node scripts/build.js",
    "typecheck": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run format:check && npm test && npm run test:python && npm run test:conformance && npm run typecheck && npm run changelog:check && npm run validate:package",
    "publint": "publint",
    "attw": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "validate:package": "npm run build && npm run publint && npm run attw",
    "prepack": "node scripts/build.js",
    "prepare": "cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "geo",
    "seo",
    "rag",
    "llm",
    "search",
    "google-gemini",
    "chatgpt",
    "perplexity",
    "citations",
    "schema",
    "json-ld",
    "robots-txt",
    "llms-txt",
    "ai-discoverability"
  ],
  "author": "Carlos Ortega González",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortega26/geo-opt.git"
  },
  "bugs": {
    "url": "https://github.com/cortega26/geo-opt/issues"
  },
  "homepage": "https://github.com/cortega26/geo-opt#readme",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "fast-xml-parser": "^5.9.3",
    "marked": "^18.0.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
